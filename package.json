{
  "name": "create-slidash",
  "version": "0.0.2",
  "description": "Craft beautiful HTML/CSS slides with AI. No builder, no bloat.",
  "keywords": [
    "slides",
    "presentation",
    "deck",
    "html",
    "css",
    "ai",
    "agentic",
    "scaffolding",
    "cli",
    "generator"
  ],
  "homepage": "https://github.com/noel-lopez/slidash#readme",
  "bugs": {
    "url": "https://github.com/noel-lopez/slidash/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noel-lopez/slidash.git"
  },
  "license": "MIT",
  "author": "Noel Lopez",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "bin": {
    "slidash": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
